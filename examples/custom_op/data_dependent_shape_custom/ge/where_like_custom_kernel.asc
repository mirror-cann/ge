#include "kernel_operator.h"

extern "C" __global__ __aicore__ void where_like_custom(GM_ADDR x, GM_ADDR y, GM_ADDR shape_buffer,
                                                            uint64_t element_count)
{
    KERNEL_TASK_TYPE_DEFAULT(KERNEL_TYPE_AIV_ONLY);
    __gm__ const bool *input = reinterpret_cast<__gm__ const bool *>(x);
    __gm__ int64_t *output = reinterpret_cast<__gm__ int64_t *>(y);
    __gm__ uint64_t *shape = reinterpret_cast<__gm__ uint64_t *>(shape_buffer);

    uint64_t true_count = 0U;
    for (uint64_t i = 0U; i < element_count; ++i) {
        if (input[i]) {
            output[true_count] = static_cast<int64_t>(i);
            ++true_count;
        }
    }

    shape[0] = 2U;
    shape[1] = true_count;
    shape[2] = 1U;
}

extern "C" void LaunchWhereLikeCustom(GM_ADDR x, GM_ADDR y, GM_ADDR shape_buffer, uint64_t element_count,
                                            void *stream)
{
    constexpr uint32_t kBlockNum = 1U;
    where_like_custom<<<kBlockNum, nullptr, stream>>>(x, y, shape_buffer, element_count);
}
